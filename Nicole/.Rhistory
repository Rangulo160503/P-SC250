setwd("~/Documents/Paradigmas/Nicole")
setwd("~/Paradigmas/Nicole")
setwd("~/Paradigmas/Nicole")
Datos_Churn <- read.csv("Datos_Churn.csv", sep = ",", stringsAsFactors = TRUE)
Datos_ChurnNuevos <- read.csv("Datos_ChurnNuevos.csv", sep = ",", stringsAsFactors = TRUE)
Datos_Churn <- read.csv("Datos_Churn.csv", sep = ",", stringsAsFactors = TRUE)
valores_unicos <- sapply(Datos_Churn, function(x) length(unique(x)))
Datos_Churn <- Datos_Churn[, valores_unicos > 1]
Datos_Churn <- na.omit(Datos_Churn)
str(Datos_Churn)
Datos_Churn$DejaBanco <- as.factor(Datos_Churn$DejaBanco)
set.seed(123)
tam <- dim(Datos_Churn)[1]
muestra <- sample(1:tam, round(tam * 0.20))
Pruebas <- Datos_Churn[muestra, ]
Aprendizaje <- Datos_Churn[-muestra, ]
install.packages("kknn")
library(kknn)
modelo_knn <- train.kknn(DejaBanco ~ ., data = Aprendizaje, kmax = 30)
prediccion_knn <- predict(modelo_knn, Pruebas[, colnames(Pruebas) != "DejaBanco"])
matriz_knn <- table(Pruebas$DejaBanco, prediccion_knn)
matriz_knn
precision_knn <- sum(diag(matriz_knn)) / sum(matriz_knn)
precision_knn
library(rpart)
modelo_arbol <- rpart(DejaBanco ~ ., data = Aprendizaje)
pred_arbol <- predict(modelo_arbol, Pruebas, type = "class")
matriz_arbol <- table(Pruebas$DejaBanco, pred_arbol)
matriz_arbol
precision_arbol <- sum(diag(matriz_arbol)) / sum(matriz_arbol)
precision_arbol
pred_final <- predict(modelo_knn, Datos_ChurnNuevos)
names(Aprendizaje)
names(Datos_ChurnNuevos)
Datos_ChurnNuevos$DejaBanco <- NULL
pred_final <- predict(modelo_knn, Datos_ChurnNuevos)
Datos_ChurnNuevos <- Datos_ChurnNuevos[, colnames(Aprendizaje)[-which(colnames(Aprendizaje) == "DejaBanco")]]
pred_final <- predict(modelo_knn, Datos_ChurnNuevos)
Aprendizaje <- Aprendizaje[, !colnames(Aprendizaje) %in% c("IdCliente", "Apellido")]
Pruebas <- Pruebas[, !colnames(Pruebas) %in% c("IdCliente", "Apellido")]
Datos_ChurnNuevos <- Datos_ChurnNuevos[, !colnames(Datos_ChurnNuevos) %in% c("IdCliente", "Apellido")]
modelo_knn <- train.kknn(DejaBanco ~ ., data = Aprendizaje, kmax = 10)
pred_final <- predict(modelo_knn, Datos_ChurnNuevos)
for(col in names(Datos_ChurnNuevos)){
if(is.factor(Aprendizaje[[col]])){
Datos_ChurnNuevos[[col]] <- factor(Datos_ChurnNuevos[[col]], levels = levels(Aprendizaje[[col]]))
}
}
pred_final <- predict(modelo_knn, Datos_ChurnNuevos)
pred_final
